// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Categoria {
  ROMANCE
  INFANTIL
  TECNOLOGIA
  HISTORIA
  CIENCIAS
}

enum StatusEmprestimo {
  EM_ANDAMENTO
  DEVOLVIDO
  ATRASADO
}

model Livro {
  id                    String            @id @default(uuid())
  titulo                String
  autor                 String
  isbn                  String            @unique
  editora               String
  quantidadeTotal       Int
  quantidadeDisponivel  Int 
  categoria             Categoria
  ano                   Int
  emprestimo            Emprestimo[]
}

model Emprestimo {
  id                    String @id        @default(uuid())
  nomeCliente           String
  emailCliente          String
  dataLocacao           DateTime          @default(now())
  dataPrevistaDevolucao DateTime
  status                StatusEmprestimo  @default(EM_ANDAMENTO)
  livroId               String 
  livro                 Livro             @relation(fields: [livroId], references: [id], onDelete: Restrict)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}